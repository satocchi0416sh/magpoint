{
  "name": "magpoint",
  "description": "A magnetic cursor that snaps to the nearest clickable element on any page — pointing assist & accessibility, built on bubble-cursor HCI research.",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "author": "Satoyoshi Hirano",
  "license": "MIT",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
